<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow -->
    <item android:top="4dp" android:left="2dp">
        <shape android:shape="oval">
            <solid android:color="#40000000" />
        </shape>
    </item>

    <!-- Outer Border (Cream) -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/eevee_cream" />
            <stroke android:width="4dp" android:color="@color/eevee_dark" />
        </shape>
    </item>

    <!-- Inner Fill (Brown) -->
    <item android:top="8dp" android:bottom="8dp" android:left="8dp" android:right="8dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="@color/eevee_brown"
                android:endColor="#D4A780"
                android:angle="270" />
        </shape>
    </item>
</layer-list>