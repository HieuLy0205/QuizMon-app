<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_selected="true">
        <shape>
            <gradient
                android:startColor="#A6C8FF"
                android:endColor="#7FB3FF"
                android:angle="0"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>


    <item>
        <shape>
            <solid android:color="#EAF4FF"/>
            <corners android:radius="18dp"/>
            <stroke android:width="1dp" android:color="#BBD4FF"/>
        </shape>
    </item>

</selector>