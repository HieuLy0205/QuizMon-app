<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/anhnenpr">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="start"
                android:src="@android:drawable/ic_media_previous"
                android:padding="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chọn Avatar"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#222"
                android:layout_marginTop="10dp" />

            <FrameLayout
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_marginTop="20dp">

                <ImageView
                    android:id="@+id/imgPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/avatar1" />

                <View
                    android:id="@+id/framePreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_avatar_border_fancy" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Avatar"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="20dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="10dp">

                <Button
                    android:id="@+id/btnAvatar1"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Avatar 1"
                    android:backgroundTint="#6A5ACD"
                    android:textColor="#FFF" />

                <Button
                    android:id="@+id/btnAvatar2"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Avatar 2"
                    android:layout_marginStart="10dp"
                    android:backgroundTint="#6A5ACD"
                    android:textColor="#FFF" />
            </LinearLayout>

            <Button
                android:id="@+id/btnAvatarVip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Avatar VIP 🔒"
                android:layout_marginTop="10dp"
                android:backgroundTint="#999999"
                android:textColor="#FFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Khung viền"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="20dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp">

                <Button
                    android:id="@+id/btnFrame1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Khung Pikachu"
                    android:backgroundTint="#6A5ACD"
                    android:textColor="#FFF" />

                <Button
                    android:id="@+id/btnFrame2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Khung Kyogre"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="#6A5ACD"
                    android:textColor="#FFF" />

                <Button
                    android:id="@+id/btnFrame3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Khung Rayquaza"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="#6A5ACD"
                    android:textColor="#FFF" />
            </LinearLayout>

            <Button
                android:id="@+id/btnFinish"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hoàn tất"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFF" />

        </LinearLayout>
    </ScrollView>

    <include layout="@layout/layout_taskbar" />

</LinearLayout>