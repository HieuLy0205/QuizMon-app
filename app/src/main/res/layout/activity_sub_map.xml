<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/sub_map_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/background"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="@null" />

    <!-- Header -->
    <include
        android:id="@+id/taskhead"
        layout="@layout/layout_taskhead"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_difficulty_btn"
        android:contentDescription="@string/btn_back"
        android:padding="12dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/taskhead"
        app:tint="@color/white" />

    <!-- Điểm số hiện tại của ải -->
    <LinearLayout
        android:id="@+id/llScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_stats_bar"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/taskhead"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Điểm ải: "
            android:textStyle="bold"
            android:textColor="#444444"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tvCurrentStageScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textStyle="bold"
            android:textColor="#E91E63"
            android:textSize="18sp"/>
    </LinearLayout>

    <!-- Progress Bar Section -->
    <FrameLayout
        android:id="@+id/flProgress"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/llScore"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:id="@+id/pbStarProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/custom_star_progress" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/star1"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/btn_star_big_off"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/star2"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintHorizontal_chainStyle="spread" />

            <ImageView
                android:id="@+id/star2"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/btn_star_big_off"
                app:layout_constraintStart_toEndOf="@+id/star1"
                app:layout_constraintEnd_toStartOf="@+id/star3"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <ImageView
                android:id="@+id/star3"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/btn_star_big_off"
                app:layout_constraintStart_toEndOf="@+id/star2"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>

    <!-- Map Grid Container -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvMapContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="150dp"
        android:layout_marginBottom="30dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/flProgress"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSubMap"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="4dp"
            android:overScrollMode="never" />

    </androidx.cardview.widget.CardView>

    <!-- Summary Overlay -->
    <FrameLayout
        android:id="@+id/summaryOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#D9000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="340dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:paddingBottom="20dp">

            <!-- Card nội dung trắng -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                app:cardCornerRadius="25dp"
                app:cardBackgroundColor="#E1F5FE"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="50dp"
                    android:paddingBottom="30dp"
                    android:paddingHorizontal="20dp"
                    android:gravity="center">

                    <!-- Nhóm sao -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="20dp">
                        <ImageView android:id="@+id/ivSumStar1" android:layout_width="60dp" android:layout_height="60dp" android:src="@android:drawable/btn_star_big_on" android:rotation="-15" android:alpha="0.2"/>
                        <ImageView android:id="@+id/ivSumStar2" android:layout_width="80dp" android:layout_height="80dp" android:src="@android:drawable/btn_star_big_on" android:layout_marginTop="-10dp" android:alpha="0.2"/>
                        <ImageView android:id="@+id/ivSumStar3" android:layout_width="60dp" android:layout_height="60dp" android:src="@android:drawable/btn_star_big_on" android:rotation="15" android:alpha="0.2"/>
                    </LinearLayout>

                    <!-- Thống kê -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✓ Câu trả lời đúng" android:textSize="18sp" android:textStyle="bold" android:textColor="#444444"/>
                        <TextView android:id="@+id/tvCorrectCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0/0" android:textSize="18sp" android:textStyle="bold" android:textColor="#000000"/>
                    </RelativeLayout>

<!--                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="20dp">-->
<!--                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⏱ Điểm thưởng" android:textSize="18sp" android:textStyle="bold" android:textColor="#444444"/>-->
<!--                        <TextView android:id="@+id/tvBonusPoints" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0" android:textSize="18sp" android:textStyle="bold" android:textColor="#000000"/>-->
<!--                    </RelativeLayout>-->

                    <!-- Tổng điểm -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_stats_bar"
                        android:paddingHorizontal="30dp"
                        android:paddingVertical="8dp"
                        android:gravity="center"
                        android:layout_marginBottom="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tổng điểm" android:textSize="14sp" android:textStyle="bold" android:textColor="#444444"/>
                        <TextView android:id="@+id/tvTotalScore" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="#F44336" android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvPercentile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bạn đang thể hiện giỏi hơn --% số người chơi khác."
                        android:gravity="center"
                        android:textColor="#0277BD"
                        android:textStyle="italic"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Banner Cấp độ -->
            <TextView
                android:id="@+id/tvSummaryTitle"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_orange_btn"
                app:backgroundTint="#F44336"
                android:text="Cấp độ 1"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:elevation="10dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Nút Tiếp tục -->
            <Button
                android:id="@+id/btnSummaryContinue"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_orange_btn"
                app:backgroundTint="#4CAF50"
                android:text="Tiếp tục"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/cvSummary"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>