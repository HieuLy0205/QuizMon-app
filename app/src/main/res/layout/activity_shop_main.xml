<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/anh_nen_shop">

    <LinearLayout
        android:id="@+id/layoutsao"
        android:layout_width="128dp"
        android:layout_height="137dp"
        android:gravity="center_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        >
        <ImageView
            android:id="@+id/imgsao"
            android:layout_width="53dp"
            android:layout_height="122dp"
            android:src="@drawable/tim3_shop_map"
            >
        </ImageView>

        <TextView
            android:id="@+id/textsao"
            android:layout_width="62dp"
            android:layout_height="36dp"
            android:background="@drawable/icon_shop_map"
            android:gravity="center"
            android:text="10"
            android:textSize="20sp"
            >
        </TextView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layouttim"
        android:layout_width="134dp"
        android:layout_height="132dp"
        android:gravity="center_vertical"
        app:layout_constraintStart_toEndOf="@id/layoutsao"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="MissingConstraints"
        >
        <ImageView
            android:id="@+id/imgtim"
            android:layout_width="60dp"
            android:layout_height="80dp"
            android:src="@drawable/su_shop_map"
            >
        </ImageView>

        <TextView
            android:id="@+id/texttim"
            android:layout_width="62dp"
            android:layout_height="36dp"
            android:background="@drawable/icon_shop_map"
            android:gravity="center"
            android:text="10"
            android:textSize="20sp"
            >
        </TextView>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutsu"
        android:layout_width="135dp"
        android:layout_height="132dp"
        android:gravity="center_vertical"
        app:layout_constraintStart_toEndOf="@id/layouttim"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="MissingConstraints"
        >
        <ImageView
            android:id="@+id/imgsu"
            android:layout_width="60dp"
            android:layout_height="80dp"
            android:src="@drawable/sao_shop_map"
            >
        </ImageView>

        <TextView
            android:id="@+id/textsu"
            android:layout_width="62dp"
            android:layout_height="36dp"
            android:background="@drawable/icon_shop_map"
            android:gravity="center"
            android:text="10"
            android:textSize="20sp"
            >
        </TextView>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutcuahang"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="5dp"
        app:layout_constraintTop_toBottomOf="@id/layouttim"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        >
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="cữa hàng"
            android:textSize="34sp"
            >
        </TextView>

        <LinearLayout
            android:id="@+id/lne_hanggoiapi"
            android:layout_width="wrap_content"
            android:layout_height="160dp"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:padding="5dp"
            app:layout_constraintTop_toBottomOf="@id/layoutcuahang"
            >
            <Button
                android:id="@+id/btn_gói_api1"
                android:layout_width="198dp"
                android:layout_height="144dp"
                android:layout_weight="1"
                android:backgroundTint="#A0B11914"
                android:padding="5dp"
                android:text="gói 1"
                android:textSize="24sp"
                >
            </Button>

            <Button
                android:id="@+id/btn_gói_api2"
                android:layout_width="212dp"
                android:layout_height="140dp"
                android:layout_weight="1"
                android:backgroundTint="#AD2C8ADB"
                android:gravity="center"
                android:paddingEnd="5dp"
                android:text="gói 2"
                android:textSize="24sp">

            </Button>

            <TextView
                android:id="@+id/text_chongoi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                >
            </TextView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/lne_hanggoiapi"
            >

            <Button
                android:id="@+id/btn_gói_api3"
                android:layout_width="193dp"
                android:layout_height="149dp"
                android:backgroundTint="#2CB8AE"
                android:gravity="center"
                android:padding="5dp"
                android:text="gói 3"
                android:textSize="24sp"
                >
            </Button>

            <Button
                android:id="@+id/btn_gói_api4"
                android:layout_width="197dp"
                android:layout_height="149dp"
                android:backgroundTint="#DBC71A"
                android:gravity="center"
                android:paddingEnd="5dp"
                android:text="gói 4"
                android:textSize="24sp"
                >
            </Button>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:gravity="center"
            >
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>