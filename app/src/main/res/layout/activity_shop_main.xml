<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layout_gravity="center">
    <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/background"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="@null" />
        <include
            android:id="@+id/layout_taskhead"
            layout="@layout/layout_taskhead"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent">
        </include>

    <LinearLayout
        android:id="@+id/layoutcuahang"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/layout_taskhead">

        <!-- Hàng 1 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:text="@string/btn_shop"
            android:textSize="34sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">
            <Button
                android:id="@+id/btn_goi_api1"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:background="@drawable/icon_ruong_mau"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/btn_goi_api2"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:background="@drawable/icon_ruong_xu"
                app:backgroundTint="@null" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="380dp"
            android:layout_height="35dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <TextView
                android:layout_width="186dp"
                android:layout_height="31dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Shop Máu"
                android:textSize="16dp"
                android:textStyle="bold"
                android:background="">
            </TextView>

            <TextView
                android:layout_width="181dp"
                android:layout_height="35dp"
                android:gravity="center"
                android:text="Shop Xu"
                android:textSize="16dp"
                android:textStyle="bold">
            </TextView>

        </LinearLayout>

        <!-- Hàng 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btn_goi_api3"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:background="@drawable/icon_ruong_exp"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/btn_goi_api4"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:background="@drawable/icon_ruong_pvp"
                app:backgroundTint="@null" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="380dp"
            android:layout_height="35dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <TextView
                android:layout_width="186dp"
                android:layout_height="31dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Nhận thưởng"
                android:textSize="16dp"
                android:textStyle="bold">
            </TextView>

            <TextView
                android:layout_width="181dp"
                android:layout_height="35dp"
                android:gravity="center"
                android:text="Trang bị PvP"
                android:textSize="16dp"
                android:textStyle="bold">
            </TextView>

        </LinearLayout>
    </LinearLayout>
    <include
        android:id="@+id/taskbar"
        layout="@layout/layout_taskbar"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
