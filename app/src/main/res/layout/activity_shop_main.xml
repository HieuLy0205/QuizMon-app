<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background">

    <!-- Top Bar: Mang, Xu, Coin -->
    <LinearLayout
        android:id="@+id/layout_top_stats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/layoutmang"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/tim3_shop_map" />
            <TextView
                android:id="@+id/textmang"
                android:layout_width="60dp"
                android:layout_height="30dp"
                android:background="@drawable/icon_shop_map"
                android:gravity="center"
                android:text="@string/text_so"
                android:textSize="16sp" />
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="4dp"
                android:src="@android:drawable/ic_input_add"
                app:tint="@color/home_green"
                android:contentDescription="@null" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutxu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/su_shop_map" />
            <TextView
                android:id="@+id/textxu"
                android:layout_width="60dp"
                android:layout_height="30dp"
                android:background="@drawable/icon_shop_map"
                android:gravity="center"
                android:text="@string/text_so"
                android:textSize="16sp" />
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="4dp"
                android:src="@android:drawable/ic_input_add"
                app:tint="@color/home_green"
                android:contentDescription="@null" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutcoin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/sao_shop_map" />
            <TextView
                android:id="@+id/textcoin"
                android:layout_width="60dp"
                android:layout_height="30dp"
                android:background="@drawable/icon_shop_map"
                android:gravity="center"
                android:text="@string/text_so"
                android:textSize="16sp" />
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="4dp"
                android:src="@android:drawable/ic_input_add"
                app:tint="@color/home_green"
                android:contentDescription="@null" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutcuahang"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/layout_top_stats">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/btn_shop"
            android:textSize="34sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Hàng 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">
            <Button
                android:id="@+id/btn_goi_api1"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:background="@drawable/icon_ruong_mang"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/btn_goi_api2"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:background="@drawable/icon_ruong_xu"
                app:backgroundTint="@null" />
        </LinearLayout>

        <!-- Hàng 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btn_goi_api3"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:background="@drawable/icon_ruong_exp"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/btn_goi_api4"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:background="@drawable/icon_ruong_pvp"
                app:backgroundTint="@null" />
        </LinearLayout>
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_margin="24dp"
        android:background="@drawable/bg_difficulty_btn"
        android:contentDescription="@string/btn_back"
        android:src="@drawable/ic_back"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:tint="@color/white" />

</androidx.constraintlayout.widget.ConstraintLayout>
