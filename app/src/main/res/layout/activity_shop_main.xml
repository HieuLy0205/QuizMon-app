<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/background">

    <LinearLayout
        android:id="@+id/layoutmang"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:gravity="center_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        >
        <ImageView
            android:id="@+id/imgmang"
            android:layout_width="53dp"
            android:layout_height="122dp"
            android:src="@drawable/tim3_shop_map"
            >
        </ImageView>

        <TextView
            android:id="@+id/textmang"
            android:layout_width="62dp"
            android:layout_height="36dp"
            android:background="@drawable/icon_shop_map"
            android:gravity="center"
            android:text="@string/text_so"
            android:textSize="20sp"
            >
        </TextView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutxu"
        android:layout_width="134dp"
        android:layout_height="132dp"
        android:gravity="center_vertical"
        app:layout_constraintStart_toEndOf="@id/layoutmang"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="MissingConstraints"
        >
        <ImageView
            android:id="@+id/imgxu"
            android:layout_width="60dp"
            android:layout_height="80dp"
            android:src="@drawable/su_shop_map"
            >
        </ImageView>

        <TextView
            android:id="@+id/textxu"
            android:layout_width="62dp"
            android:layout_height="36dp"
            android:background="@drawable/icon_shop_map"
            android:gravity="center"
            android:text="@string/text_so"
            android:textSize="20sp"
            >
        </TextView>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutcoin"
        android:layout_width="135dp"
        android:layout_height="132dp"
        android:gravity="center_vertical"
        app:layout_constraintStart_toEndOf="@id/layoutxu"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="MissingConstraints"
        >
        <ImageView
            android:id="@+id/imgcoin"
            android:layout_width="60dp"
            android:layout_height="80dp"
            android:src="@drawable/sao_shop_map"
            >
        </ImageView>

        <TextView
            android:id="@+id/textcoin"
            android:layout_width="62dp"
            android:layout_height="36dp"
            android:background="@drawable/icon_shop_map"
            android:gravity="center"
            android:text="@string/text_so"
            android:textSize="20sp"
            >
        </TextView>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutcuahang"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="5dp"
        app:layout_constraintTop_toBottomOf="@id/layoutxu"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        >

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/btn_shop"
            android:textSize="34sp"
            >
        </TextView>

        <LinearLayout
            android:id="@+id/lne_hanggoiapi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:padding="5dp"
            app:layout_constraintTop_toBottomOf="@id/layoutcuahang"
            >

            <Button
                android:id="@+id/btn_goi_api1"
                android:layout_width="185dp"
                android:layout_height="140dp"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:background="@drawable/icon_ruong_mang"
                android:padding="5dp"
                android:textSize="24sp"
                app:backgroundTint="@null"
                app:cornerRadius="0dp">
            </Button>

            <Button
                android:id="@+id/btn_goi_api2"
                android:layout_width="212dp"
                android:layout_height="140dp"
                android:layout_weight="1"
                android:background="@drawable/icon_ruong_xu"
                android:gravity="center"
                android:padding="20dp"
                android:layout_marginStart="5dp"
                android:textSize="24sp"
                app:backgroundTint="@null"
                app:cornerRadius="0dp"
                >
            </Button>

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:padding="5dp"
            app:layout_constraintTop_toBottomOf="@id/lne_hanggoiapi">

            <Button
                android:id="@+id/btn_goi_api3"
                android:layout_width="193dp"
                android:layout_height="149dp"
                android:layout_weight="1"
                android:background="@drawable/icon_ruog_exp"
                android:gravity="center"
                android:padding="5dp"
                android:layout_marginEnd="5dp"
                android:textSize="24sp"
                app:backgroundTint="@null"
                app:cornerRadius="0dp">
            </Button>

            <Button
                android:id="@+id/btn_goi_api4"
                android:layout_width="197dp"
                android:layout_height="149dp"
                android:background="@drawable/icon_ruong_pvp"
                android:gravity="center"
                android:textStyle="bold"
                android:layout_marginStart="5dp"
                android:paddingRight="5dp"
                android:textSize="24sp"
                app:backgroundTint="@null"
                app:cornerRadius="0dp">
            </Button>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:gravity="center"
            >
        </LinearLayout>
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="87dp"
        android:layout_height="43dp"
        android:layout_margin="16dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="576dp"
        android:background="#CD19D5BC"
        android:contentDescription="@string/btn_back"
        android:padding="12dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_back"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutcuahang"
        app:layout_constraintVertical_bias="1.0"
        app:tint="@color/white"
        tools:ignore="ImageContrastCheck" />

</androidx.constraintlayout.widget.ConstraintLayout>