<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="75dp"
    android:background="@drawable/taskbar_bg"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:baselineAligned="false"
    android:paddingStart="4dp"
    android:paddingEnd="4dp">

    <!-- Hồ sơ -->
    <LinearLayout
        android:id="@+id/nav_profile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/iv_nav_profile"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/hoso_taskbar"
            android:contentDescription="@null" />
        <TextView
            android:id="@+id/tv_nav_profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hoso"
            android:textSize="15sp"
            android:textColor="@color/taskbar_text"
            android:textStyle="bold" />
        <View
            android:id="@+id/indicator_profile"
            android:layout_width="28dp"
            android:layout_height="5dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_wood_indicator"
            android:visibility="invisible" />
    </LinearLayout>

    <!-- Lịch sử -->
    <LinearLayout
        android:id="@+id/nav_history"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/iv_nav_history"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/lichsu_taskbar"
            android:contentDescription="@null" />
        <TextView
            android:id="@+id/tv_nav_history"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ls"
            android:textSize="15sp"
            android:textColor="@color/taskbar_text"
            android:textStyle="bold" />
        <View
            android:id="@+id/indicator_history"
            android:layout_width="28dp"
            android:layout_height="5dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_wood_indicator"
            android:visibility="invisible" />
    </LinearLayout>

    <!-- Trang chủ -->
    <LinearLayout
        android:id="@+id/nav_home"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/iv_nav_home"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/home_taskbar"
            android:contentDescription="@null" />
        <TextView
            android:id="@+id/tv_nav_home"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home"
            android:textSize="15sp"
            android:textColor="@color/taskbar_text"
            android:textStyle="bold" />
        <View
            android:id="@+id/indicator_home"
            android:layout_width="28dp"
            android:layout_height="5dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_wood_indicator"
            android:visibility="invisible" />
    </LinearLayout>

    <!-- Cửa hàng -->
    <LinearLayout
        android:id="@+id/nav_shop"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/iv_nav_shop"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/shop_taskbar"
            android:contentDescription="@null" />
        <TextView
            android:id="@+id/tv_nav_shop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/shop"
            android:textSize="15sp"
            android:textColor="@color/taskbar_text"
            android:textStyle="bold" />
        <View
            android:id="@+id/indicator_shop"
            android:layout_width="28dp"
            android:layout_height="5dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_wood_indicator"
            android:visibility="invisible" />
    </LinearLayout>

    <!-- Menu -->
    <LinearLayout
        android:id="@+id/nav_menu"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/iv_nav_menu"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/menu_taskbar"
            android:contentDescription="@null" />
        <TextView
            android:id="@+id/tv_nav_menu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/menu"
            android:textSize="15sp"
            android:textColor="@color/taskbar_text"
            android:textStyle="bold" />
        <View
            android:id="@+id/indicator_menu"
            android:layout_width="28dp"
            android:layout_height="5dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_wood_indicator"
            android:visibility="invisible" />
    </LinearLayout>

</LinearLayout>