<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header với streak -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_streak_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_current_streak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 Chuỗi: 0 ngày"
                    android:textSize="18sp"
                    android:textColor="#FF9800"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_longest_streak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏆 Dài nhất: 0 ngày"
                    android:textSize="14sp"
                    android:textColor="#666"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Biểu đồ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 Thống kê 7 ngày qua"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <View
            android:id="@+id/chart_view"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="24dp"/>

        <!-- Tổng kết -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📈 Tổng kết toàn bộ"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_total_correct"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Đúng: 0"
                android:textColor="#4CAF50"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tv_total_wrong"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sai: 0"
                android:textColor="#F44336"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tv_total_questions"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tổng: 0"
                android:textColor="#2196F3"
                android:textSize="16sp"/>
        </LinearLayout>

        <!-- Chi tiết từng ngày -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📅 Chi tiết từng ngày"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view_daily_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>

    </LinearLayout>
</ScrollView>