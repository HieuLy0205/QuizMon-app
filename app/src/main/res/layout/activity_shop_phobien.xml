<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/background">

    <LinearLayout
        android:id="@+id/sao_shop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:layout_width="69dp"
                android:layout_height="69dp"
                android:src="@drawable/sao_shop_map"
                android:contentDescription="Icon Shop"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/btn_play"
                android:backgroundTint="#89D9D6D6"
                android:gravity="center"
                android:text="@string/text_shopphobien"
                android:textSize="24sp"
                android:textColor="#1B1919"
                android:textStyle="bold"
                android:backgroundTintMode="src_atop">
            </TextView>
        </LinearLayout>

        <TextView

            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="24sp"
            android:gravity="center"
            android:text="@string/text_ShopNv">

        </TextView>

        <LinearLayout
            android:id="@+id/lne_task_1"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/text_nv1"
                android:layout_width="230dp"
                android:layout_height="49dp"
                android:layout_gravity="center"
                android:gravity="center_vertical"
                android:text="@string/text_nhiemvu1"
                android:padding="8dp"
                android:textSize="18sp"
                android:textStyle="bold">
            </TextView>

            <ImageView
                android:layout_width="48dp"
                android:layout_height="49dp"
                android:layout_gravity="center"
                android:background="@drawable/sao_shop_map">
            </ImageView>

            <Button
                android:id="@+id/btn_Nv1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:backgroundTint="#B697EB80"
                android:text="hoàn thành"
                android:textColor="#161313"
                android:textStyle="bold">
            </Button>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="230dp"
                android:layout_height="48dp"
                android:text="@string/text_nhiemvu2"
                android:layout_gravity="center"
                android:gravity="center_vertical"
                android:padding="8dp"
                android:textSize="18sp"
                android:textStyle="bold">
            </TextView>

            <ImageView
                android:layout_width="48dp"
                android:layout_height="49dp"
                android:layout_gravity="center"
                android:background="@drawable/sao_shop_map">
            </ImageView>

            <Button
                android:id="@+id/btn_Nv2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:backgroundTint="#B6EB8C80"
                android:text="hoàn thành"
                android:textColor="#161313"
                android:textStyle="bold">
            </Button>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="230dp"
                android:layout_height="49dp"
                android:gravity="center_vertical"
                android:text="@string/text_nhiemvu3"
                android:padding="8dp"
                android:textSize="18sp"
                android:textStyle="bold">
            </TextView>

            <ImageView
                android:layout_width="48dp"
                android:layout_height="49dp"
                android:layout_gravity="center"
                android:background="@drawable/sao_shop_map">
            </ImageView>

            <Button
                android:id="@+id/btn_Nv3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:backgroundTint="#B65CD9F0"
                android:text="hoàn thành"
                android:textColor="#161313"
                android:textStyle="bold">
            </Button>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="230dp"
                android:layout_height="49dp"
                android:text="@string/text_nhiemvu4"
                android:textSize="18sp"
                android:padding="8dp"
                android:gravity="center_vertical"
                android:textStyle="bold">
            </TextView>

            <ImageView
                android:layout_width="48dp"
                android:layout_height="49dp"
                android:layout_gravity="center"
                android:background="@drawable/sao_shop_map">
            </ImageView>

            <Button
                android:id="@+id/btn_Nv4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:backgroundTint="#EBD280"
                android:text="hoàn thành"
                android:textColor="#161313"
                android:textStyle="bold">
            </Button>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="232dp"
                android:layout_height="62dp"
                android:gravity="center_vertical"
                android:padding="8dp"
                android:text="@string/text_nhiemvu5"
                android:textSize="18sp"
                android:textStyle="bold"></TextView>

            <ImageView
                android:layout_width="48dp"
                android:layout_height="49dp"
                android:layout_gravity="center"
                android:background="@drawable/sao_shop_map"></ImageView>

            <Button
                android:id="@+id/btn_Nv5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:backgroundTint="#B6C680EB"
                android:text="hoàn thành"
                android:textColor="#161313"
                android:textStyle="bold"></Button>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_margin="24dp"
            android:background="@drawable/bg_difficulty_btn"
            android:contentDescription="@string/btn_back"
            android:padding="12dp"
            android:layout_gravity="bottom"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_back" />
    </LinearLayout>


</ScrollView>