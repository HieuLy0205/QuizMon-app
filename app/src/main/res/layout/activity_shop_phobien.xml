<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/background">

    <LinearLayout
        android:id="@+id/sao_shop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:layout_width="69dp"
                android:layout_height="69dp"
                android:src="@drawable/sao_shop_map"
                android:contentDescription="Icon Shop" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@drawable/bt_dia"
                android:backgroundTint="#FC94918E"
                android:gravity="center"
                android:text="@string/text_shopphobien"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView

            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="24sp"
            android:gravity="center"
            android:text="Thanh nhiệm cụ hằng ngày">

        </TextView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="258dp"
                android:layout_height="41dp"
                android:text="@string/text_nhiemvu"
                android:textSize="18sp"
                android:textStyle="bold">
            </TextView>

            <Button
                android:id="@+id/btn_Nv1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:backgroundTint="#B680DAEB"
                android:text="hoàn thành">
            </Button>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="258dp"
                android:layout_height="41dp"
                android:text="@string/text_nhiemvu"
                android:textSize="18sp"
                android:textStyle="bold">
            </TextView>

            <Button
                android:id="@+id/btn_Nv2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:backgroundTint="#B680DAEB"
                android:text="hoàn thành">
            </Button>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="258dp"
                android:layout_height="41dp"
                android:text="@string/text_nhiemvu"
                android:textSize="18sp"
                android:textStyle="bold">
            </TextView>

            <Button
                android:id="@+id/btn_Nv3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:backgroundTint="#B680DAEB"
                android:text="hoàn thành">
            </Button>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="258dp"
                android:layout_height="41dp"
                android:text="@string/text_nhiemvu"
                android:textSize="18sp"
                android:textStyle="bold">
            </TextView>

            <Button
                android:id="@+id/btn_Nv4"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:backgroundTint="#B680DAEB"
                android:text="hoàn thành">
            </Button>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="258dp"
                android:layout_height="41dp"
                android:text="@string/text_nhiemvu"
                android:textSize="18sp"
                android:textStyle="bold">
            </TextView>

            <Button
                android:id="@+id/btn_Nv5"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:backgroundTint="#B680DAEB"
                android:text="hoàn thành">
            </Button>
        </LinearLayout>

    </LinearLayout>

</ScrollView>