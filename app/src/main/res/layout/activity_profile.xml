<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/anhnenpr">

    <!-- Thanh trạng thái phía trên -->
    <include
        android:id="@+id/taskhead"
        layout="@layout/layout_taskhead"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/taskhead"
        app:layout_constraintBottom_toTopOf="@id/taskbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <!-- TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hồ sơ nhân vật"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="16dp"/>

            <!-- AVATAR -->
            <FrameLayout
                android:layout_width="140dp"
                android:layout_height="140dp">

                <ImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"/>

                <View
                    android:id="@+id/frame"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
            </FrameLayout>

            <!-- BUTTON -->
            <Button
                android:id="@+id/btnEditAvatar"
                android:layout_width="200dp"
                android:layout_height="48dp"
                android:text="Đổi avatar"
                android:textColor="#FFF"
                android:layout_marginTop="12dp"/>

            <!-- INFO -->
            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginTop="12dp"/>

            <TextView
                android:id="@+id/tvAge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000"/>

            <TextView
                android:id="@+id/tvGender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#000000"/>

            <TextView
                android:id="@+id/tvTopics"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#000000"
                android:layout_marginBottom="16dp"/>

            <!-- EDIT BUTTON -->
            <Button
                android:id="@+id/btnEditProfile"
                android:layout_width="200dp"
                android:layout_height="48dp"
                android:text="Chỉnh sửa hồ sơ"/>

            <!-- RESET -->
            <Button
                android:id="@+id/btnReset"
                android:layout_width="200dp"
                android:layout_height="48dp"
                android:text="Reset dữ liệu"
                android:backgroundTint="#E53935"
                android:textColor="#FFF"
                android:layout_marginTop="10dp"/>

            <!-- FORM -->
            <LinearLayout
                android:id="@+id/layoutEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="16dp">

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Tên"
                    android:textColor="#000000"
                    android:textColorHint="#555555"
                    android:backgroundTint="#000000" />

                <EditText
                    android:id="@+id/etAge"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Tuổi"
                    android:inputType="number"
                    android:textColor="#000000"
                    android:textColorHint="#555555"
                    android:backgroundTint="#000000" />

                <EditText
                    android:id="@+id/etTopics"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Sở thích (phân cách ,)"
                    android:textColor="#000000"
                    android:textColorHint="#555555"
                    android:backgroundTint="#000000" />

                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="200dp"
                    android:layout_height="48dp"
                    android:text="Lưu"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <include
        android:id="@+id/taskbar"
        layout="@layout/layout_taskbar"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
