<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Header dùng chung -->
    <include
        android:id="@+id/taskhead"
        layout="@layout/layout_taskhead"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/anhnenpr"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="24dp"
            android:paddingTop="28dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hồ sơ nhân vật"
                android:textColor="#222222"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp" />

            <FrameLayout
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/avatar1"
                    android:scaleType="centerCrop" />

                <View
                    android:id="@+id/frame"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_avatar_border_fancy" />

            </FrameLayout>

            <TextView
                android:id="@+id/tvAge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tuổi: 38"
                android:textColor="#3A3A3A"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvGender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giới tính: Khác"
                android:textColor="#4A4A4A"
                android:textSize="17sp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvTopics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sở thích: Thể thao, Khoa học, Xã hội"
                android:textColor="#4A4A4A"
                android:textSize="17sp"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Nhập tên"
                android:textColor="#222222"
                android:textColorHint="#8A8A8A"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/bg_input"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="220dp"
                android:layout_height="52dp"
                android:text="Lưu tên"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_button_primary"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btnEditProfile"
                android:layout_width="220dp"
                android:layout_height="52dp"
                android:text="Chỉnh sửa hồ sơ"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_button_primary" />

        </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/taskbar"
        layout="@layout/layout_taskbar"
        android:layout_width="match_parent"
        android:layout_height="75dp" />

</LinearLayout>