<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/tupet"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background">

    <ImageView
        android:id="@+id/taskhead_1"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/background"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="@null" />

    <include
        android:id="@+id/layout_taskhead"
        layout="@layout/layout_taskhead"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />
    <TextView
        android:id="@+id/textView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="16dp"
        android:text="TỦ ĐỒ PET"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toBottomOf="@id/layout_taskhead" />

    <!-- Thân máy: Chia làm 2 cột -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView">

        <!-- Cột trái: Loại vật phẩm (Thú/Trứng) -->
        <ListView
            android:id="@+id/lv_vat_in_tu"
            android:layout_width="110dp"
            android:layout_height="match_parent"
            android:background="@drawable/task_right_tupet"
            android:divider="@android:color/transparent"
            android:dividerHeight="4dp"
            android:padding="4dp" />

        <!-- Cột phải: Danh sách và Khung xem trước -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/tv_danhsach"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Danh sách"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#070606"
                android:layout_marginBottom="8dp"/>

            <!-- Danh sách các con Pet đang có -->
            <ListView
                android:id="@+id/lv_kho_dung"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:dividerHeight="2dp" />

            <!-- === KHUNG XEM TRƯỚC PET (PHẦN BẠN CẦN) === -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cv_pet_preview"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:strokeWidth="2dp"
                app:strokeColor="@color/black">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#FFFFFF">

                    <ImageView
                        android:id="@+id/img_pet_preview"
                        android:layout_width="180dp"
                        android:layout_height="180dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/pet_an_0" />

                    <TextView
                        android:id="@+id/tv_selected_pet_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chưa chọn Pet"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_margin="24dp"
                android:background="@drawable/bg_difficulty_btn"
                android:contentDescription="@string/btn_back"
                android:padding="12dp"
                android:layout_gravity="bottom"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_back" />


        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>