<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/anhnenpr"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="24dp"
            android:paddingTop="56dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cá nhân hoá trò chơi của bạn"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1F1F1F"
                android:gravity="center"
                android:layout_marginBottom="28dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Giới tính"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333"
                android:layout_marginBottom="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="30dp">

                <Button
                    android:id="@+id/btnMale"
                    style="@style/GenderButton"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_gender_selector"
                    android:backgroundTint="@null"
                    android:textColor="@color/gender_text_selector"
                    android:text="Nam" />

                <Button
                    android:id="@+id/btnFemale"
                    style="@style/GenderButton"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="6dp"
                    android:background="@drawable/bg_gender_selector"
                    android:backgroundTint="@null"
                    android:textColor="@color/gender_text_selector"
                    android:text="Nữ" />

                <Button
                    android:id="@+id/btnOther"
                    style="@style/GenderButton"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_gender_selector"
                    android:backgroundTint="@null"
                    android:textColor="@color/gender_text_selector"
                    android:text="Khác" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chủ đề yêu thích (chọn ít nhất 3)"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#333"
                android:layout_marginBottom="14dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:useDefaultMargins="true"
                android:layout_marginBottom="32dp">

                <include
                    android:id="@+id/topic_phim"
                    layout="@layout/item_topic" />

                <include
                    android:id="@+id/topic_xahoi"
                    layout="@layout/item_topic" />

                <include
                    android:id="@+id/topic_lichsu"
                    layout="@layout/item_topic" />

                <include
                    android:id="@+id/topic_thethao"
                    layout="@layout/item_topic" />

                <include
                    android:id="@+id/topic_dialy"
                    layout="@layout/item_topic" />

                <include
                    android:id="@+id/topic_khoahoc"
                    layout="@layout/item_topic" />

                <include
                    android:id="@+id/topic_tunhien"
                    layout="@layout/item_topic" />

                <include
                    android:id="@+id/topic_vanhoa"
                    layout="@layout/item_topic" />
            </GridLayout>

            <Button
                android:id="@+id/btnNext"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_button_primary"
                android:elevation="6dp"
                android:text="Tiếp tục"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:alpha="0.5" />

        </LinearLayout>
    </ScrollView>

    <include layout="@layout/layout_taskbar" />

</LinearLayout>