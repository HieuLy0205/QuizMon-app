<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/streak_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EDF1F4">

    <!-- Header Section (Phần nền màu) -->
    <View
        android:id="@+id/header_bg"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="#F8BBD0"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Thanh trạng thái phía trên (TaskHead) -->
    <include
        android:id="@+id/taskhead"
        layout="@layout/layout_taskhead"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Nút Quay lại -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:src="@drawable/ic_back"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="10dp"
        android:elevation="10dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/btn_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/taskhead"
        app:tint="#000000" />

    <!-- Avatar Section -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivAvatar"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_marginStart="24dp"
        android:src="@drawable/dragon_c2_f1"
        android:background="@color/white"
        android:padding="3dp"
        app:layout_constraintBottom_toBottomOf="@id/header_bg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_bg"
        app:shapeAppearanceOverlay="@style/CircleImage"
        app:strokeColor="#FFFFFF"
        app:strokeWidth="4dp" />

    <TextView
        android:id="@+id/tvName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:text="Fonix"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#333333"
        app:layout_constraintTop_toBottomOf="@id/header_bg"
        app:layout_constraintStart_toEndOf="@id/ivAvatar" />

    <!-- Tabs Layout (Chỉ còn Thành tích và Thống kê) -->
    <LinearLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/tvName">

        <LinearLayout
            android:id="@+id/tabThanhTich"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:id="@+id/ivTabThanhTich"
                android:layout_width="26dp" android:layout_height="26dp" android:src="@drawable/hoso_taskbar" />
            <TextView
                android:id="@+id/tvTabThanhTich"
                android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thành tích" android:textSize="12sp" android:textStyle="bold" />
            <View
                android:id="@+id/indicatorThanhTich"
                android:layout_width="80dp" android:layout_height="3dp" android:background="#333333" android:layout_marginTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabThongKe"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:id="@+id/ivTabThongKe"
                android:layout_width="26dp" android:layout_height="26dp" android:src="@drawable/lichsu_taskbar" android:alpha="0.4" />
            <TextView
                android:id="@+id/tvTabThongKe"
                android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thống kê" android:textSize="12sp" android:textColor="#999999" />
            <View
                android:id="@+id/indicatorThongKe"
                android:layout_width="80dp" android:layout_height="3dp" android:background="#333333" android:layout_marginTop="4dp" android:visibility="invisible" />
        </LinearLayout>
    </LinearLayout>

    <!-- Container cho Fragment Thống kê -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tabLayout"
        app:layout_constraintBottom_toTopOf="@id/taskbar" />

    <!-- Scrollable Content (Danh sách Thành tích) -->
    <ScrollView
        android:id="@+id/layoutThanhTich"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tabLayout"
        app:layout_constraintBottom_toTopOf="@id/taskbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Item 1: Chiến binh -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">
                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="60dp" android:layout_height="60dp"
                    android:src="@drawable/dragon_c2_f1"
                    android:padding="4dp" app:shapeAppearanceOverlay="@style/CircleImage"
                    android:background="#F0F0F0" />
                <LinearLayout
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="16dp" android:orientation="vertical">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chiến binh" android:textStyle="bold" android:textColor="#455A64" android:textSize="15sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="14%" android:textStyle="bold" android:textColor="#455A64" />
                    </RelativeLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thắng 100 trận đấu" android:textSize="12sp" android:textColor="#78909C" />
                    <ProgressBar style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="8dp" android:progress="14" android:progressTint="#8BC34A" />
                </LinearLayout>
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <!-- Item 2: Người hâm mộ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">
                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="60dp" android:layout_height="60dp"
                    android:src="@drawable/dragon_pet_2"
                    android:padding="4dp" app:shapeAppearanceOverlay="@style/CircleImage"
                    android:background="#F0F0F0" />
                <LinearLayout
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="16dp" android:orientation="vertical">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Người hâm mộ" android:textStyle="bold" android:textColor="#455A64" android:textSize="15sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="40%" android:textStyle="bold" android:textColor="#455A64" />
                    </RelativeLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Đăng nhập 7 ngày liên tiếp" android:textSize="12sp" android:textColor="#78909C" />
                    <ProgressBar style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="8dp" android:progress="40" android:progressTint="#FFC107" />
                </LinearLayout>
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <!-- Item 3: Thợ săn -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">
                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="60dp" android:layout_height="60dp"
                    android:src="@drawable/dragon_pet_4"
                    android:padding="4dp" app:shapeAppearanceOverlay="@style/CircleImage"
                    android:background="#F0F0F0" />
                <LinearLayout
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="16dp" android:orientation="vertical">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thợ săn" android:textStyle="bold" android:textColor="#455A64" android:textSize="15sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="20%" android:textStyle="bold" android:textColor="#455A64" />
                    </RelativeLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thu thập 10 loại thú cưng" android:textSize="12sp" android:textColor="#78909C" />
                    <ProgressBar style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="8dp" android:progress="20" android:progressTint="#2196F3" />
                </LinearLayout>
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <!-- Item 4: Đam mê -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">
                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="60dp" android:layout_height="60dp"
                    android:src="@drawable/dragon_pet_6"
                    android:padding="4dp" app:shapeAppearanceOverlay="@style/CircleImage"
                    android:background="#F0F0F0" />
                <LinearLayout
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="16dp" android:orientation="vertical">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Đam mê" android:textStyle="bold" android:textColor="#455A64" android:textSize="15sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="65%" android:textStyle="bold" android:textColor="#455A64" />
                    </RelativeLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Trả lời 500 câu hỏi" android:textSize="12sp" android:textColor="#78909C" />
                    <ProgressBar style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="8dp" android:progress="65" android:progressTint="#E91E63" />
                </LinearLayout>
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <!-- Item 5: Bậc thầy -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">
                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="60dp" android:layout_height="60dp"
                    android:src="@drawable/dragon_pet_8"
                    android:padding="4dp" app:shapeAppearanceOverlay="@style/CircleImage"
                    android:background="#F0F0F0" />
                <LinearLayout
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="16dp" android:orientation="vertical">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bậc thầy" android:textStyle="bold" android:textColor="#455A64" android:textSize="15sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="5%" android:textStyle="bold" android:textColor="#455A64" />
                    </RelativeLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hoàn thành 20 ải khó" android:textSize="12sp" android:textColor="#78909C" />
                    <ProgressBar style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="8dp" android:progress="5" android:progressTint="#9C27B0" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Taskbar (Thanh điều hướng dưới) -->
    <include
        android:id="@+id/taskbar"
        layout="@layout/layout_taskbar"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>