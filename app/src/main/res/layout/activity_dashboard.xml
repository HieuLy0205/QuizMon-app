<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F9">

    <!-- Thanh chỉ số phía trên (Stars, Coins, Hearts) -->
    <LinearLayout
        android:id="@+id/layout_top_stats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center"
        android:elevation="10dp"
        android:translationZ="10dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_stats_bar"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:gravity="center_vertical"
            android:layout_marginEnd="8dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/sao_shop_map" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_star_count"
                android:textColor="@color/black"
                android:layout_marginStart="6dp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_stats_bar"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:gravity="center_vertical"
            android:layout_marginEnd="8dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/diem_shop_map" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_coin_count"
                android:textColor="@color/black"
                android:layout_marginStart="6dp"
                android:textStyle="bold" />
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_input_add"
                android:layout_marginStart="4dp"
                app:tint="#4CAF50" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_stats_bar"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/tim3_shop_map" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_time"
                android:textColor="@color/black"
                android:layout_marginStart="6dp"
                android:textStyle="bold" />
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_input_add"
                android:layout_marginStart="4dp"
                app:tint="#4CAF50" />
        </LinearLayout>
    </LinearLayout>

    <!-- Header Background -->
    <ImageView
        android:id="@+id/ivHeaderBg"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:src="@drawable/background"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/viewProfileBg"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@color/white"
        app:layout_constraintTop_toBottomOf="@id/ivHeaderBg" />

    <!-- Avatar -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivAvatar"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:src="@drawable/pet001_rong_c2"
        android:padding="4dp"
        android:background="@color/white"
        app:strokeColor="@color/white"
        app:strokeWidth="4dp"
        app:shapeAppearanceOverlay="@style/CircleImage"
        app:layout_constraintBottom_toBottomOf="@id/ivHeaderBg"
        app:layout_constraintTop_toBottomOf="@id/ivHeaderBg"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="24dp" />

    <ImageView
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/sao_shop_map"
        android:contentDescription="@null"
        app:layout_constraintBottom_toBottomOf="@id/ivAvatar"
        app:layout_constraintEnd_toEndOf="@id/ivAvatar" />

    <TextView
        android:id="@+id/tvName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/default_user_name"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginStart="20dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/ivHeaderBg"
        app:layout_constraintStart_toEndOf="@id/ivAvatar" />

    <ImageView
        android:id="@+id/btnEdit"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:src="@android:drawable/ic_menu_edit"
        android:background="@drawable/bg_stats_bar"
        android:padding="10dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintBottom_toBottomOf="@id/ivAvatar"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="#888888" />

    <!-- Tab Bar -->
    <LinearLayout
        android:id="@+id/layoutTabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/white"
        android:paddingTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/viewProfileBg">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:orientation="vertical">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/hoso_taskbar"
                android:alpha="0.4"
                android:contentDescription="@null" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_thanh_tich"
                android:textSize="12sp"
                android:textColor="#BBBBBB" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:orientation="vertical">
            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/lichsu_taskbar"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_thong_ke"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#333333" />
            <View
                android:layout_width="80dp"
                android:layout_height="3dp"
                android:background="#333333"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:orientation="vertical">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/shop_taskbar"
                android:alpha="0.4"
                android:contentDescription="@null" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_mua_hang"
                android:textSize="12sp"
                android:textColor="#BBBBBB" />
        </LinearLayout>
    </LinearLayout>

    <!-- Stat Cards -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/layoutTabs"
        app:layout_constraintBottom_toBottomOf="parent">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:padding="12dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#A5D6A7">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:padding="16dp">
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        android:layout_alignParentEnd="true"
                        app:tint="#FFFFFF" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/text_so"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_above="@id/tvDesc1"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/tvDesc1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/stat_levels_completed"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:layout_alignParentBottom="true" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#9FA8DA">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:padding="16dp">
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@android:drawable/ic_menu_recent_history"
                        android:layout_alignParentEnd="true"
                        app:tint="#FFFFFF" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stat_since"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_above="@id/tvDesc2"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/tvDesc2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/default_date_stat"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:layout_alignParentBottom="true" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#4DD0E1">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:padding="16dp">
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@android:drawable/ic_menu_help"
                        android:layout_alignParentEnd="true"
                        app:tint="#FFFFFF" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stat_questions_value"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_above="@id/tvDesc3"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/tvDesc3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/stat_questions_answered"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:layout_alignParentBottom="true" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#CE93D8">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:padding="16dp">
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@android:drawable/checkbox_on_background"
                        android:layout_alignParentEnd="true"
                        app:tint="#FFFFFF" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/percent_67"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_above="@id/tvDesc4"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/tvDesc4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/stat_correct_rate"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:layout_alignParentBottom="true" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

        </GridLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>