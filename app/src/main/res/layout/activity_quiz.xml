<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Ảnh nền chính đồng nhất với MainActivity -->
    <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/background"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp">
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:layout_gravity="start|center_vertical" />
            <TextView
                android:id="@+id/tvQuestionNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Câu hỏi"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#795548"
                android:layout_gravity="center"
                tools:ignore="HardcodedText"/>
        </FrameLayout>

        <ProgressBar
            android:id="@+id/progressQuiz"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progress="10"
            android:layout_marginBottom="10dp"/>

        <!-- 4 Ô phụ trợ kèm số lượng -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="10dp">

            <!-- 50/50 -->
            <LinearLayout
                android:id="@+id/btnFiftyFifty"
                style="@style/PowerUpItemStyle"
                android:orientation="vertical"
                android:gravity="center">
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_fifty_fifty" />
                    <TextView
                        android:id="@+id/tvCountFiftyFifty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:background="@drawable/bg_stats_bar"
                        android:paddingHorizontal="4dp"
                        android:text="0"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        tools:ignore="SmallSp"/>
                </FrameLayout>
                <TextView style="@style/PowerUpTextStyle" android:text="50/50"/>
            </LinearLayout>

            <!-- Cơ hội 2 -->
            <LinearLayout
                android:id="@+id/btnDoubleChance"
                style="@style/PowerUpItemStyle"
                android:orientation="vertical"
                android:gravity="center">
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_skip" />
                    <TextView
                        android:id="@+id/tvCountDoubleChance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:background="@drawable/bg_stats_bar"
                        android:paddingHorizontal="4dp"
                        android:text="0"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        tools:ignore="SmallSp"/>
                </FrameLayout>
                <TextView style="@style/PowerUpTextStyle" android:text="Cơ hội 2"/>
            </LinearLayout>

            <!-- Gợi ý -->
            <LinearLayout
                android:id="@+id/btnRevealAnswer"
                style="@style/PowerUpItemStyle"
                android:orientation="vertical"
                android:gravity="center">
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_reveal_answer" />
                    <TextView
                        android:id="@+id/tvCountRevealAnswer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:background="@drawable/bg_stats_bar"
                        android:paddingHorizontal="4dp"
                        android:text="0"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        tools:ignore="SmallSp"/>
                </FrameLayout>
                <TextView style="@style/PowerUpTextStyle" android:text="Gợi ý"/>
            </LinearLayout>

            <!-- x2 Điểm -->
            <LinearLayout
                android:id="@+id/btnDoubleScore"
                style="@style/PowerUpItemStyle"
                android:orientation="vertical"
                android:gravity="center">
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_double_score" />
                    <TextView
                        android:id="@+id/tvCountDoubleScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:background="@drawable/bg_stats_bar"
                        android:paddingHorizontal="4dp"
                        android:text="0"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        tools:ignore="SmallSp"/>
                </FrameLayout>
                <TextView style="@style/PowerUpTextStyle" android:text="x2 Điểm"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Card câu hỏi -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <TextView
                    android:id="@+id/tvQuestion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="16dp"
                    android:textSize="17sp"
                    android:textColor="#4E342E"
                    android:lineSpacingMultiplier="1.2"
                    android:text="@string/tv_question"/>
            </ScrollView>
        </androidx.cardview.widget.CardView>

        <!-- Container 4 nút đáp án -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/answerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnA"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="60dp"
                android:padding="12dp"
                android:textSize="14sp"
                android:textColor="#4E342E"
                android:textAllCaps="false"
                android:gravity="start|center_vertical"
                android:backgroundTint="#FFFFFF"
                app:strokeColor="#BCAAA4"
                app:strokeWidth="2dp"
                app:cornerRadius="16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/btnB"
                app:layout_constraintHorizontal_weight="1"
                android:layout_margin="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnB"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="60dp"
                android:padding="12dp"
                android:textSize="14sp"
                android:textColor="#4E342E"
                android:textAllCaps="false"
                android:gravity="start|center_vertical"
                android:backgroundTint="#FFFFFF"
                app:strokeColor="#BCAAA4"
                app:strokeWidth="2dp"
                app:cornerRadius="16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@+id/btnA"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_weight="1"
                android:layout_margin="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnC"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="60dp"
                android:padding="12dp"
                android:textSize="14sp"
                android:textColor="#4E342E"
                android:textAllCaps="false"
                android:gravity="start|center_vertical"
                android:backgroundTint="#FFFFFF"
                app:strokeColor="#BCAAA4"
                app:strokeWidth="2dp"
                app:cornerRadius="16dp"
                app:layout_constraintTop_toBottomOf="@+id/btnA"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/btnD"
                app:layout_constraintHorizontal_weight="1"
                android:layout_margin="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnD"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="60dp"
                android:padding="12dp"
                android:textSize="14sp"
                android:textColor="#4E342E"
                android:textAllCaps="false"
                android:gravity="start|center_vertical"
                android:backgroundTint="#FFFFFF"
                app:strokeColor="#BCAAA4"
                app:strokeWidth="2dp"
                app:cornerRadius="16dp"
                app:layout_constraintTop_toBottomOf="@+id/btnB"
                app:layout_constraintStart_toEndOf="@+id/btnC"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_weight="1"
                android:layout_margin="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Panel giải thích -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardExplanation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#E3F2FD">
            <TextView
                android:id="@+id/tvExplanation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:textSize="13sp"
                android:textColor="#1565C0"
                android:lineSpacingMultiplier="1.4"
                tools:text="Giải thích hiển thị sau khi chọn đáp án."/>
        </androidx.cardview.widget.CardView>

        <!-- Nút xác nhận -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirm"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Xác nhận"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            android:enabled="false"
            app:cornerRadius="26dp"
            tools:ignore="HardcodedText"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
