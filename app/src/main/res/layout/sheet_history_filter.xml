<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <!-- Drag handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="6dp"
        android:background="@drawable/bg_drag_handle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:fontFamily="@font/san-serif-bold"
            android:text="Bộ lọc"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <!-- Lọc theo thể loại -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/san-serif-black"
            android:text="THỂ LOẠI"
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            android:letterSpacing="0.05" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            app:singleSelection="true"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <!-- Lọc theo loại đáp án -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/san-serif-black"
            android:text="LOẠI ĐÁP ÁN"
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            android:letterSpacing="0.05" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_answer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="22dp"
            app:singleSelection="true"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <!-- Nút Thiết lập lại+ Áp dụng -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_reset"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:fontFamily="@font/san-serif-black"
                android:text="Thiết lập lại"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_apply"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_orange"
                android:fontFamily="@font/san-serif-black"
                android:text="Áp dụng"
                android:textColor="@color/white"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>