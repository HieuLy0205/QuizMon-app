<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Thanh trạng thái phía trên (Căn giữa toàn bộ nhóm) -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:background="@drawable/background_taskhead"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingVertical="14dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Ngôi sao / Điểm -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="5dp"
            android:background="@drawable/bg_stats_bar"
            android:backgroundTint="@color/white"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingTop="5dp"
            android:paddingEnd="12dp"
            android:paddingBottom="5dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/sao_shop_map" />

            <TextView
                android:id="@+id/textcoins"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="0"
                android:textColor="#100F0E"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imgcoins"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="1dp"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_input_add"
                app:tint="@color/home_green" />
        </LinearLayout>

        <!-- Xu / Tiền -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="5dp"
            android:background="@drawable/bg_stats_bar"
            android:backgroundTint="@color/white"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingTop="5dp"
            android:paddingEnd="12dp"
            android:paddingBottom="5dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/su_shop_map" />

            <TextView
                android:id="@+id/textxu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="0"
                android:textColor="#100F0E"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imgxu"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="1dp"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_input_add"
                app:tint="@color/home_green" />
        </LinearLayout>

        <!-- Kinh nghiệm (Exp) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="5dp"
            android:background="@drawable/bg_stats_bar"
            android:backgroundTint="@color/white"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingTop="5dp"
            android:paddingEnd="12dp"
            android:paddingBottom="5dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/diem_shop_map" />

            <TextView
                android:id="@+id/head_text_exp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="0"
                android:textColor="#070607"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Tim / Mạng -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="5dp"
            android:background="@drawable/bg_stats_bar"
            android:backgroundTint="@color/white"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingTop="5dp"
            android:paddingEnd="12dp"
            android:paddingBottom="5dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/tim3_shop_map" />

            <TextView
                android:id="@+id/head_text_heart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="00:00"
                android:textColor="#E91E63"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>