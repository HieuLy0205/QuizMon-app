<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F8FF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- TITLE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chúng tôi có thể giúp gì?"
            android:textColor="#1F2A44"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="28dp" />

        <!-- DESCRIPTION -->
        <EditText
            android:id="@+id/etDescription"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:hint="Hãy mô tả vấn đề của bạn"
            android:gravity="top"
            android:padding="14dp"
            android:textColor="#1F2A44"
            android:textColorHint="#8A94A6"
            android:background="#FFFFFF"
            android:inputType="textMultiLine"
            android:layout_marginBottom="14dp" />

        <!-- NAME -->
        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:hint="Tên của bạn"
            android:padding="14dp"
            android:textColor="#1F2A44"
            android:textColorHint="#8A94A6"
            android:background="#FFFFFF"
            android:inputType="textPersonName"
            android:layout_marginBottom="14dp" />

        <!-- EMAIL -->
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:hint="Email của bạn"
            android:padding="14dp"
            android:textColor="#1F2A44"
            android:textColorHint="#8A94A6"
            android:background="#FFFFFF"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="26dp" />

        <!-- BUTTON -->
        <Button
            android:id="@+id/btnSend"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Gửi đi"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="17sp"
            android:backgroundTint="#2F80ED" />

    </LinearLayout>
</ScrollView>