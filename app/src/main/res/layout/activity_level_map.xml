<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/clLevelMapRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/map_bg">

    <!-- View để hiển thị background động -->
    <ImageView
        android:id="@+id/ivBackground1"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_map"
        android:contentDescription="@null" />

    <ImageView
        android:id="@+id/ivBackground2"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0"
        android:contentDescription="@null" />

    <!-- RecyclerView để hiển thị danh sách ải không giới hạn -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLevelMap"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:clipToPadding="false"
        android:paddingTop="60dp"
        android:paddingBottom="40dp"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Header cố định -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_difficulty_btn"
        android:contentDescription="@string/btn_back"
        android:padding="12dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white"
        tools:ignore="ImageContrastCheck" />

</androidx.constraintlayout.widget.ConstraintLayout>