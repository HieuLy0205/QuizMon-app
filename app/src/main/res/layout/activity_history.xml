<!--Layout giao diện lịch sử chính-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_cream"
    android:id="@+id/history_root">

    <!-- ===== HEADER ===== -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="2dp"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Tiêu đề + nút lọc -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-black"
                android:text="Lịch sử"
                android:textColor="@color/text_primary"
                android:textSize="22sp" />

            <!-- Nút lọc -->
            <FrameLayout
                android:id="@+id/btn_filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_filter_btn"
                android:padding="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_filter"
                        app:tint="@color/orange_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:fontFamily="sans-serif-black"
                        android:text="Lọc"
                        android:textColor="@color/orange_primary"
                        android:textSize="13sp" />

                    <!-- Badge số -->
                    <TextView
                        android:id="@+id/tv_filter_badge"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/bg_btn_orange"
                        android:fontFamily="sans-serif-black"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:visibility="gone" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <!-- Thống kê đúng / sai / tổng -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="12dp">

            <!-- Đúng -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_stat_correct"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/tv_stat_correct"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="0"
                    android:textColor="@color/correct_green"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Đúng"
                    android:textColor="@color/correct_green_dark"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Sai -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_stat_wrong"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/tv_stat_wrong"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="0"
                    android:textColor="@color/wrong_red"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Sai"
                    android:textColor="@color/wrong_red_dark"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Tổng -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_stat_total"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/tv_stat_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="0"
                    android:textColor="@color/blue_primary"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Tổng"
                    android:textColor="@color/blue_dark"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ===== DANH SÁCH ===== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_history"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingHorizontal="14dp"
        android:paddingVertical="12dp"
        app:layout_constraintBottom_toTopOf="@id/nav_bottom"
        app:layout_constraintTop_toBottomOf="@id/header" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:text="Chưa có lịch sử nào"
        android:textColor="@color/text_hint"
        android:textSize="15sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/nav_bottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header" />

    <!-- ===== NAV BAR (Đã được kích hoạt mục Lịch sử) ===== -->
    <LinearLayout
        android:id="@+id/nav_bottom"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:background="@drawable/taskbar_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:baselineAligned="false"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Hồ sơ -->
        <LinearLayout
            android:id="@+id/nav_profile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/hoso_taskbar" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hoso"
                android:textSize="15sp"
                android:textColor="@color/taskbar_text"
                android:textStyle="bold" />
            <View
                android:layout_width="28dp"
                android:layout_height="5dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/bg_wood_indicator"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- Lịch sử (ĐÃ SET ACTIVE) -->
        <LinearLayout
            android:id="@+id/nav_history"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/lichsu_taskbar" />
            <TextView
                android:id="@+id/tv_nav_history"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ls"
                android:textSize="15sp"
                android:textColor="#A52A2A"
                android:textStyle="bold" />
            <View
                android:id="@+id/indicator_history"
                android:layout_width="28dp"
                android:layout_height="5dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/bg_wood_indicator"
                android:visibility="visible" /> <!-- Hiện thanh gạch chân gỗ -->
        </LinearLayout>

        <!-- Trang chủ -->
        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/home_taskbar" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home"
                android:textSize="15sp"
                android:textColor="@color/taskbar_text"
                android:textStyle="bold" />
            <View
                android:layout_width="28dp"
                android:layout_height="5dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/bg_wood_indicator"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- Cửa hàng -->
        <LinearLayout
            android:id="@+id/nav_shop"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/shop_taskbar" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/shop"
                android:textSize="15sp"
                android:textColor="@color/taskbar_text"
                android:textStyle="bold" />
            <View
                android:layout_width="28dp"
                android:layout_height="5dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/bg_wood_indicator"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- Menu -->
        <LinearLayout
            android:id="@+id/nav_menu"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/menu_taskbar" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/menu"
                android:textSize="15sp"
                android:textColor="@color/taskbar_text"
                android:textStyle="bold" />
            <View
                android:layout_width="28dp"
                android:layout_height="5dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/bg_wood_indicator"
                android:visibility="invisible" />
        </LinearLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>