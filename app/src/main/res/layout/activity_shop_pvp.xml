<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/background">

    <LinearLayout
        android:id="@+id/pvp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/icon_ruong_pvp"
                android:contentDescription="Icon Shop" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="99dp"
                android:background="@drawable/bt_dia"
                android:backgroundTint="#FC94918E"
                android:gravity="center"
                android:text="@string/text_shoppvp"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="87dp"
            android:layout_height="43dp"
            android:layout_margin="16dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="576dp"
            android:background="#CD19D5BC"
            android:contentDescription="@string/btn_back"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutcuahang"
            app:layout_constraintVertical_bias="1.0"
            app:tint="@color/white" />
    </LinearLayout>

</ScrollView>
